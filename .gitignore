
# Node modules
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Build outputs
dist/
build/

# Optional npm cache
.npm
.pnp.*

# Debugger files
.vscode/
.idea/

# Coverage
coverage/
nyc_output/

# Optional lock files
package-lock.json
yarn.lock
pnpm-lock.yaml


# Ignore everything inside public/temp
/public/temp/*

# But do not ignore this .gitignore itself (if placed inside public/temp)
!/public/temp/.gitignore
.ignore/*

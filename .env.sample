# Port the server runs on
APP_PORT=""

# MongoDB connection string
# Local => mongodb://localhost:27017/database_name
# Cloud => mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGODB_URI=""

# Frontend URL allowed to access the API
# Local => http://localhost:3000
# Cloud => https://yourdomain.com
CORS_ORIGIN=""

# Long random string used to sign access tokens (use an online generator)
ACCESS_TOKEN_SECRET=""

# Access token lifetime — short lived
# 60 (60 seconds), 15m (15 minutes), 1h (1 hour), 7d (7 days)
ACCESS_TOKEN_EXPIRY=""

# Long random string used to sign refresh tokens (use an online generator)
REFRESH_TOKEN_SECRET=""

# Refresh token lifetime — long lived
# 60 (60 seconds), 15m (15 minutes), 1h (1 hour), 7d (7 days)
REFRESH_TOKEN_EXPIRY=""

# Found in your Cloudinary dashboard under Account Details
CLOUDINARY_CLOUD_NAME=""

# Used with CLOUDINARY_SECRET to authenticate server-side requests
CLOUDINARY_KEY=""

# Used with CLOUDINARY_KEY to authenticate server-side requests
CLOUDINARY_SECRET=""
